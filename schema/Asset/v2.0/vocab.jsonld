        "@value": "assetId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Provider-assigned unique identifier for the asset",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Asset"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
