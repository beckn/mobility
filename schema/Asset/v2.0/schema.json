{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Asset",
  "type": "object",
  "description": "A specific mobility resource (vehicle, bike, scooter, or car) managed and made available for use by a mobility provider.",
  "properties": {
    "assetId": {
      "description": "Provider-assigned unique identifier for the asset",
      "type": "string"
    },
    "assetType": {
      "description": "Vehicle type classification of this asset",
      "$ref": "https://schema.beckn.io/VehicleType/v2.0/schema.json"
    },
    "currentStatus": {
      "description": "Real-time operational status of this asset",
      "$ref": "https://schema.beckn.io/VehicleStatus/v2.0/schema.json"
    },
    "currentLocation": {
      "description": "Current geographic location of the asset",
      "$ref": "https://schema.beckn.io/Location/v2.0/schema.json"
    },
    "id": {
      "description": "Unique identifier for the item",
      "type": "string"
    },
    "descriptor": {
      "description": "Human-readable description of the item",
      "$ref": "https://schema.beckn.io/Descriptor/v2.1/schema.json"
    },
    "categoryId": {
      "description": "Category code classifying the item",
      "$ref": "https://schema.beckn.io/CategoryCode/v2.1/schema.json"
    },
    "price": {
      "description": "Price specification for this item",
      "$ref": "https://schema.beckn.io/PriceSpecification/v2.1/schema.json"
    },
    "quantity": {
      "description": "Available quantity of the item",
      "$ref": "https://schema.beckn.io/Quantity/v2.0/schema.json"
    },
    "tags": {
      "description": "Tags associated with the item",
      "type": "string"
    }
  },
  "additionalProperties": false
}
