  "@graph": [
    {
      "@id": "beckn:PickupPolicy",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "PickupPolicy",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A set of rules governing the locations and conditions under which passengers may be picked up for a ride-hailing or on-demand transport service.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:Geofence"
      }
    },
    {
      "@id": "beckn:allowedPickupAreas",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "allowedPickupAreas",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic areas where pickup is permitted",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PickupPolicy"
      },
      "rdfs:range": {
        "@id": "beckn:Geofence"
      },
      "rdfs:seeAlso": {
        "@id": "../Geofence/v2.0/vocab.jsonld#beckn:Geofence"
      }
    },
    {
      "@id": "beckn:pickupConditions",
