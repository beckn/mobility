      "rdfs:label": {
        "@value": "pickupConditions",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Conditions that must be met for a valid pickup",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PickupPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
