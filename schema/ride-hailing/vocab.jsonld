{
  "@context": {
    "@version": 1.1,
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "mobility": "./vocab.jsonld#"
  },
  "@graph": [
    {
      "@id": "mobility:MobilityEntity",
      "@type": "rdfs:Class",
      "rdfs:label": "Mobility entity",
      "rdfs:comment": "Top-level class for all ride-hailing mobility ontology entities."
    },
    {
      "@id": "mobility:Actor",
      "@type": "rdfs:Class",
      "rdfs:label": "Actor",
      "rdfs:comment": "An entity (person/organization/software agent) that participates in a ride-hailing transaction.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Artifact",
      "@type": "rdfs:Class",
      "rdfs:label": "Artifact",
      "rdfs:comment": "A created artifact/document/token produced or consumed during a transaction.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:OperationalEvent",
      "@type": "rdfs:Class",
      "rdfs:label": "Operational event",
      "rdfs:comment": "An operational event that occurs during the lifecycle of a ride.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Policy",
      "@type": "rdfs:Class",
      "rdfs:label": "Policy",
      "rdfs:comment": "A set of rules or terms governing behavior, charges, and constraints.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:Feature",
      "@type": "rdfs:Class",
      "rdfs:label": "Feature",
      "rdfs:comment": "A capability/amenity/characteristic applicable to a service, vehicle, or experience.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Constraint",
      "@type": "rdfs:Class",
      "rdfs:label": "Constraint",
      "rdfs:comment": "A quantitative or qualitative constraint or limit applicable to an offering or fulfillment.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Entitlement",
      "@type": "rdfs:Class",
      "rdfs:label": "Entitlement",
      "rdfs:comment": "A token/voucher/coupon/pass/permit representing rights or benefits.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:Alert",
      "@type": "rdfs:Class",
      "rdfs:label": "Alert",
      "rdfs:comment": "A notification about an issue, disruption, or notable situation affecting a ride.",
      "rdfs:subClassOf": ["mobility:OperationalEvent"]
    },
    {
      "@id": "mobility:State",
      "@type": "rdfs:Class",
      "rdfs:label": "State",
      "rdfs:comment": "A state value within a state machine for ride or fulfillment lifecycle.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:TermSet",
      "@type": "rdfs:Class",
      "rdfs:label": "Term set",
      "rdfs:comment": "A controlled vocabulary set of terms.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Term",
      "@type": "rdfs:Class",
      "rdfs:label": "Term",
      "rdfs:comment": "A single term value within a term set.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:MoneyAmount",
      "@type": "rdfs:Class",
      "rdfs:label": "Money amount",
      "rdfs:comment": "A monetary amount with currency.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Quantity",
      "@type": "rdfs:Class",
      "rdfs:label": "Quantity",
      "rdfs:comment": "A numeric value with unit.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:GeoPoint",
      "@type": "rdfs:Class",
      "rdfs:label": "Geopoint",
      "rdfs:comment": "A latitude/longitude point.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:TimeWindow",
      "@type": "rdfs:Class",
      "rdfs:label": "Time window",
      "rdfs:comment": "A window or tolerance of time (earliest/latest).",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:DocumentRef",
      "@type": "rdfs:Class",
      "rdfs:label": "Document reference",
      "rdfs:comment": "A reference to an external or embedded document/media asset.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:Telemetry",
      "@type": "rdfs:Class",
      "rdfs:label": "Telemetry",
      "rdfs:comment": "Telemetry and tracking related entities.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },

    {
      "@id": "mobility:RideHailingService",
      "@type": "rdfs:Class",
      "rdfs:label": "Ride-hailing service",
      "rdfs:comment": "A service offering on-demand ride-hailing trips.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:RideOption",
      "@type": "rdfs:Class",
      "rdfs:label": "Ride option",
      "rdfs:comment": "A selectable option representing a service class + vehicle category + pricing basis.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:RideRequest",
      "@type": "rdfs:Class",
      "rdfs:label": "Ride request",
      "rdfs:comment": "A rider's intent specifying pickup/drop, time, preferences and constraints.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Trip",
      "@type": "rdfs:Class",
      "rdfs:label": "Trip",
      "rdfs:comment": "A booked ride instance representing the operational fulfillment of a ride request.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:TripLeg",
      "@type": "rdfs:Class",
      "rdfs:label": "Trip leg",
      "rdfs:comment": "A segment/leg within a trip (supports waypoints and shared rides).",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:TripItinerary",
      "@type": "rdfs:Class",
      "rdfs:label": "Trip itinerary",
      "rdfs:comment": "A structured itinerary of a trip: ordered stops and legs with estimates.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:FulfillmentStop",
      "@type": "rdfs:Class",
      "rdfs:label": "Fulfillment stop",
      "rdfs:comment": "A typed stop in an itinerary (pickup/dropoff/waypoint/stand).",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:PickupDropoffPoint",
      "@type": "rdfs:Class",
      "rdfs:label": "Pickup/dropoff point",
      "rdfs:comment": "A precise pickup/drop point including location reference, geofence and instructions.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:StopPlace",
      "@type": "rdfs:Class",
      "rdfs:label": "Stop place",
      "rdfs:comment": "A named stop/stand/hub/station used as a reference location.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:LocationRef",
      "@type": "rdfs:Class",
      "rdfs:label": "Location reference",
      "rdfs:comment": "A stable reference to a location such as a stand id, POI id, or platform id.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Geofence",
      "@type": "rdfs:Class",
      "rdfs:label": "Geofence",
      "rdfs:comment": "A geographic fence (polygon/circle) constraining pickup/drop/serviceability.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Route",
      "@type": "rdfs:Class",
      "rdfs:label": "Route",
      "rdfs:comment": "A route representation used for constrained, pooled, or suggested routing.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },

    {
      "@id": "mobility:Rider",
      "@type": "rdfs:Class",
      "rdfs:label": "Rider",
      "rdfs:comment": "The beneficiary/consumer of the trip (may differ from payer).",
      "rdfs:subClassOf": ["mobility:Actor"]
    },
    {
      "@id": "mobility:Driver",
      "@type": "rdfs:Class",
      "rdfs:label": "Driver",
      "rdfs:comment": "The operational actor who drives/runs the ride-hailing vehicle.",
      "rdfs:subClassOf": ["mobility:Actor"]
    },
    {
      "@id": "mobility:DriverIdentity",
      "@type": "rdfs:Class",
      "rdfs:label": "Driver identity",
      "rdfs:comment": "Identity attributes presented to riders (masked contact, display name, photo ref).",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:DriverCredential",
      "@type": "rdfs:Class",
      "rdfs:label": "Driver credential",
      "rdfs:comment": "A credential/verification artifact for a driver (license, badge, check).",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:DriverSkill",
      "@type": "rdfs:Class",
      "rdfs:label": "Driver skill",
      "rdfs:comment": "A skill/capability of a driver.",
      "rdfs:subClassOf": ["mobility:Feature"]
    },
    {
      "@id": "mobility:PassengerGroup",
      "@type": "rdfs:Class",
      "rdfs:label": "Passenger group",
      "rdfs:comment": "Party composition and passenger category counts.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:ContactHandle",
      "@type": "rdfs:Class",
      "rdfs:label": "Contact handle",
      "rdfs:comment": "A contact endpoint with masking/consent attributes.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },

    {
      "@id": "mobility:Vehicle",
      "@type": "rdfs:Class",
      "rdfs:label": "Vehicle",
      "rdfs:comment": "A vehicle assigned to a trip (category, registration, make/model, attributes).",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:VehicleCategory",
      "@type": "rdfs:Class",
      "rdfs:label": "Vehicle category",
      "rdfs:comment": "A category descriptor for ride-hailing vehicles.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:VehicleFeature",
      "@type": "rdfs:Class",
      "rdfs:label": "Vehicle feature",
      "rdfs:comment": "A vehicle amenity/capability feature.",
      "rdfs:subClassOf": ["mobility:Feature"]
    },
    {
      "@id": "mobility:AccessibilityFeature",
      "@type": "rdfs:Class",
      "rdfs:label": "Accessibility feature",
      "rdfs:comment": "An accessibility capability applicable to vehicle/service.",
      "rdfs:subClassOf": ["mobility:Feature"]
    },
    {
      "@id": "mobility:ConnectivityFeature",
      "@type": "rdfs:Class",
      "rdfs:label": "Connectivity feature",
      "rdfs:comment": "A connectivity/digital amenity feature.",
      "rdfs:subClassOf": ["mobility:Feature"]
    },
    {
      "@id": "mobility:Accessory",
      "@type": "rdfs:Class",
      "rdfs:label": "Accessory",
      "rdfs:comment": "A physical accessory offered or required (helmet/child-seat).",
      "rdfs:subClassOf": ["mobility:Feature"]
    },
    {
      "@id": "mobility:ServiceClass",
      "@type": "rdfs:Class",
      "rdfs:label": "Service class",
      "rdfs:comment": "A tier/class of service (economy/premium/pool/XL).",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },

    {
      "@id": "mobility:OperationalPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "Operational policy",
      "rdfs:comment": "A policy artifact applicable to a ride lifecycle.",
      "rdfs:subClassOf": ["mobility:Policy"]
    },
    {
      "@id": "mobility:WaitingPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "Waiting policy",
      "rdfs:comment": "Rules for waiting time, grace periods, and waiting charges.",
      "rdfs:subClassOf": ["mobility:OperationalPolicy"]
    },
    {
      "@id": "mobility:NoShowPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "No-show policy",
      "rdfs:comment": "Rules for rider/driver no-show handling and penalties.",
      "rdfs:subClassOf": ["mobility:OperationalPolicy"]
    },
    {
      "@id": "mobility:CancellationPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "Cancellation policy",
      "rdfs:comment": "Rules for cancellations and penalties/refunds.",
      "rdfs:subClassOf": ["mobility:OperationalPolicy"]
    },
    {
      "@id": "mobility:PickupPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "Pickup policy",
      "rdfs:comment": "Rules for pickup behavior (zones, meet points, verification).",
      "rdfs:subClassOf": ["mobility:OperationalPolicy"]
    },
    {
      "@id": "mobility:DropPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "Drop policy",
      "rdfs:comment": "Rules for dropoff behavior (restrictions, toll handling).",
      "rdfs:subClassOf": ["mobility:OperationalPolicy"]
    },
    {
      "@id": "mobility:SafetyPolicy",
      "@type": "rdfs:Class",
      "rdfs:label": "Safety policy",
      "rdfs:comment": "Safety-related rules and emergency protocols.",
      "rdfs:subClassOf": ["mobility:OperationalPolicy"]
    },
    {
      "@id": "mobility:Instruction",
      "@type": "rdfs:Class",
      "rdfs:label": "Instruction",
      "rdfs:comment": "Operational instruction text or structured directive.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },

    {
      "@id": "mobility:PricingModel",
      "@type": "rdfs:Class",
      "rdfs:label": "Pricing model",
      "rdfs:comment": "The pricing basis used to compute fares (upfront, metered, time-distance).",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:FareEstimate",
      "@type": "rdfs:Class",
      "rdfs:label": "Fare estimate",
      "rdfs:comment": "A pre-booking quote or estimate under assumptions.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:FareBreakup",
      "@type": "rdfs:Class",
      "rdfs:label": "Fare breakup",
      "rdfs:comment": "A line-item breakup of the fare.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:PriceComponent",
      "@type": "rdfs:Class",
      "rdfs:label": "Price component",
      "rdfs:comment": "A single line item in a fare breakup.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:TollCharge",
      "@type": "rdfs:Class",
      "rdfs:label": "Toll charge",
      "rdfs:comment": "A toll line-item component.",
      "rdfs:subClassOf": ["mobility:PriceComponent"]
    },
    {
      "@id": "mobility:Surcharge",
      "@type": "rdfs:Class",
      "rdfs:label": "Surcharge",
      "rdfs:comment": "A surcharge line-item (airport/peak/platform fee).",
      "rdfs:subClassOf": ["mobility:PriceComponent"]
    },
    {
      "@id": "mobility:Discount",
      "@type": "rdfs:Class",
      "rdfs:label": "Discount",
      "rdfs:comment": "A discount line-item.",
      "rdfs:subClassOf": ["mobility:PriceComponent"]
    },
    {
      "@id": "mobility:Tax",
      "@type": "rdfs:Class",
      "rdfs:label": "Tax",
      "rdfs:comment": "A tax line-item.",
      "rdfs:subClassOf": ["mobility:PriceComponent"]
    },
    {
      "@id": "mobility:PaymentInstrument",
      "@type": "rdfs:Class",
      "rdfs:label": "Payment instrument",
      "rdfs:comment": "Payment method descriptor.",
      "rdfs:subClassOf": ["mobility:MobilityEntity"]
    },
    {
      "@id": "mobility:Coupon",
      "@type": "rdfs:Class",
      "rdfs:label": "Coupon",
      "rdfs:comment": "A coupon/promo entitlement.",
      "rdfs:subClassOf": ["mobility:Entitlement"]
    },
    {
      "@id": "mobility:Receipt",
      "@type": "rdfs:Class",
      "rdfs:label": "Receipt",
      "rdfs:comment": "Ride receipt/invoice summary for rider.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },

    {
      "@id": "mobility:ServiceAlert",
      "@type": "rdfs:Class",
      "rdfs:label": "Service alert",
      "rdfs:comment": "Alert affecting a ride (driver delayed, reroute, service disruption).",
      "rdfs:subClassOf": ["mobility:Alert"]
    },
    {
      "@id": "mobility:Incident",
      "@type": "rdfs:Class",
      "rdfs:label": "Incident",
      "rdfs:comment": "An incident during or about a ride (safety issue, dispute, accident).",
      "rdfs:subClassOf": ["mobility:OperationalEvent"]
    },
    {
      "@id": "mobility:EmergencyEvent",
      "@type": "rdfs:Class",
      "rdfs:label": "Emergency event",
      "rdfs:comment": "An emergency/SOS event.",
      "rdfs:subClassOf": ["mobility:OperationalEvent"]
    },
    {
      "@id": "mobility:SupportCase",
      "@type": "rdfs:Class",
      "rdfs:label": "Support case",
      "rdfs:comment": "A support ticket/case raised post-fulfillment.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:Rating",
      "@type": "rdfs:Class",
      "rdfs:label": "Rating",
      "rdfs:comment": "Numeric rating provided post-fulfillment.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:Review",
      "@type": "rdfs:Class",
      "rdfs:label": "Review",
      "rdfs:comment": "Textual review provided post-fulfillment.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:Feedback",
      "@type": "rdfs:Class",
      "rdfs:label": "Feedback",
      "rdfs:comment": "Structured feedback tags/reasons.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },
    {
      "@id": "mobility:LostAndFoundItem",
      "@type": "rdfs:Class",
      "rdfs:label": "Lost and found item",
      "rdfs:comment": "Lost item report artifact.",
      "rdfs:subClassOf": ["mobility:Artifact"]
    },

    {
      "@id": "mobility:TelemetryStream",
      "@type": "rdfs:Class",
      "rdfs:label": "Telemetry stream",
      "rdfs:comment": "Tracking channel metadata (URL/channel/token).",
      "rdfs:subClassOf": ["mobility:Telemetry"]
    },
    {
      "@id": "mobility:TrackingPoint",
      "@type": "rdfs:Class",
      "rdfs:label": "Tracking point",
      "rdfs:comment": "A telemetry sample point with coordinates and movement.",
      "rdfs:subClassOf": ["mobility:Telemetry"]
    },

    {
      "@id": "mobility:TripState",
      "@type": "rdfs:Class",
      "rdfs:label": "Trip state",
      "rdfs:comment": "Trip lifecycle state value.",
      "rdfs:subClassOf": ["mobility:State"]
    },
    {
      "@id": "mobility:FulfillmentState",
      "@type": "rdfs:Class",
      "rdfs:label": "Fulfillment state",
      "rdfs:comment": "Fulfillment lifecycle state value.",
      "rdfs:subClassOf": ["mobility:State"]
    },

    {
      "@id": "mobility:hasFeature",
      "@type": "rdf:Property",
      "rdfs:label": "Has feature",
      "rdfs:comment": "Associates an entity with one or more features.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Feature"]
    },
    {
      "@id": "mobility:hasPolicy",
      "@type": "rdf:Property",
      "rdfs:label": "Has policy",
      "rdfs:comment": "Associates an entity with one or more policies.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Policy"]
    },
    {
      "@id": "mobility:hasConstraint",
      "@type": "rdf:Property",
      "rdfs:label": "Has constraint",
      "rdfs:comment": "Associates an entity with one or more constraints.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Constraint"]
    },
    {
      "@id": "mobility:hasParticipant",
      "@type": "rdf:Property",
      "rdfs:label": "Has participant",
      "rdfs:comment": "Associates a transaction/fulfillment with one or more participating actors.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Actor"]
    },
    {
      "@id": "mobility:hasEntitlement",
      "@type": "rdf:Property",
      "rdfs:label": "Has entitlement",
      "rdfs:comment": "Associates a transaction/ride with applied or issued entitlements.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Entitlement"]
    },
    {
      "@id": "mobility:hasInstruction",
      "@type": "rdf:Property",
      "rdfs:label": "Has instruction",
      "rdfs:comment": "Associates an entity with one or more operational instructions.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Instruction"]
    },
    {
      "@id": "mobility:hasAlert",
      "@type": "rdf:Property",
      "rdfs:label": "Has alert",
      "rdfs:comment": "Associates an entity with one or more alerts.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:Alert"]
    },
    {
      "@id": "mobility:hasState",
      "@type": "rdf:Property",
      "rdfs:label": "Has state",
      "rdfs:comment": "Associates an entity with a state value.",
      "rdfs:domain": ["mobility:MobilityEntity"],
      "rdfs:range": ["mobility:State"]
    },

    {
      "@id": "mobility:serviceClass",
      "@type": "rdf:Property",
      "rdfs:label": "Service class",
      "rdfs:comment": "Service class for a ride option.",
      "rdfs:subPropertyOf": ["mobility:hasFeature"],
      "rdfs:domain": ["mobility:RideOption"],
      "rdfs:range": ["mobility:ServiceClass"]
    },
    {
      "@id": "mobility:vehicleCategory",
      "@type": "rdf:Property",
      "rdfs:label": "Vehicle category",
      "rdfs:comment": "Vehicle category for a ride option.",
      "rdfs:subPropertyOf": ["mobility:hasFeature"],
      "rdfs:domain": ["mobility:RideOption"],
      "rdfs:range": ["mobility:VehicleCategory"]
    },
    {
      "@id": "mobility:features",
      "@type": "rdf:Property",
      "rdfs:label": "Features",
      "rdfs:comment": "Features offered for an option/service.",
      "rdfs:subPropertyOf": ["mobility:hasFeature"],
      "rdfs:domain": ["mobility:RideOption", "mobility:RideHailingService", "mobility:Vehicle"],
      "rdfs:range": ["mobility:Feature"]
    },
    {
      "@id": "mobility:accessibilityFeatures",
      "@type": "rdf:Property",
      "rdfs:label": "Accessibility features",
      "rdfs:comment": "Accessibility capabilities offered.",
      "rdfs:subPropertyOf": ["mobility:features"],
      "rdfs:domain": ["mobility:RideOption", "mobility:Vehicle"],
