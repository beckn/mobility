{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:DistributionChannel",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "DistributionChannel",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A channel or platform through which fare products or tickets are sold or distributed to end customers.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "https://schema.org/ItemList"
      }
    },
    {
      "@id": "beckn:channelType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "channelType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of distribution channel (e.g. ONLINE, TICKET_OFFICE, MOBILE_APP)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:DistributionChannel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:channelName",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "channelName",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable name of this distribution channel",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:DistributionChannel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "url",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "URL to access this distribution channel",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:DistributionChannel"
      },
      "rdfs:range": {
        "@id": "xsd:anyURI"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/URL"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the catalog",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:DistributionChannel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the catalog",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:DistributionChannel"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:tags",
