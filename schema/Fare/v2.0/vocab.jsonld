  },
  "@graph": [
    {
      "@id": "beckn:Fare",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Fare",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The monetary cost of travel for a specific journey or service, calculated based on applicable fare rules and passenger categories.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/PriceSpecification"
        },
        {
          "@id": "beckn:FareLegRule"
        }
      ]
    },
    {
      "@id": "beckn:fareId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "fareId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the fare",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Fare"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:amount",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "amount",
        "@language": "en"
      },
      "rdfs:comment": {
