{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:SupportCase",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "SupportCase",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A formal customer service inquiry, complaint, or request raised by a passenger or provider through the mobility platform's support system.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:caseType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "caseType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of support case (e.g. COMPLAINT, INQUIRY, TECHNICAL)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:priority",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "priority",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Priority level of the case (LOW, MEDIUM, HIGH, URGENT)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:reportedAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "reportedAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp when the case was reported",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:resolvedAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "resolvedAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp when the case was resolved",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:orderId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "orderId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the contract/order against which support is required",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:ticketIds",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "ticketIds",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifiers of any open support tickets",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#SupportTicket"
      }
    },
    {
      "@id": "beckn:callbackPhone",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "callbackPhone",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Telephone number for callback support",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:SupportCase"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
