      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "title",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Title or label of this price component",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FareComponent"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
