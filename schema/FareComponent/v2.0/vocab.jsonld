      "rdfs:label": {
        "@value": "tags",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Tags associated with this price component",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FareComponent"
      },
      "rdfs:range": {
        "@id": "xsd:string"
