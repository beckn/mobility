  },
  "@graph": [
    {
      "@id": "beckn:Line",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Line",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A named, branded public transport service identified by a number or name, typically operating over one or more routes.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "beckn:Network"
        },
        {
          "@id": "beckn:Operator"
        }
      ]
    },
    {
      "@id": "beckn:lineId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "lineId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "GTFS or NeTEx identifier for the line",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Line"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
