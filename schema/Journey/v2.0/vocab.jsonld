{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Journey",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Journey",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A complete travel itinerary from origin to destination, potentially comprising multiple legs using different transport modes.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/Trip"
        },
        {
          "@id": "beckn:Leg"
        }
      ]
    },
    {
      "@id": "beckn:origin",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "origin",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Origin location of the journey",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:destination",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "destination",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Destination location of the journey",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:departureTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "departureTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Planned departure time",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:arrivalTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "arrivalTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Planned arrival time",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:legs",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "legs",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Ordered list of legs comprising this journey",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "beckn:Leg"
      },
      "rdfs:seeAlso": {
        "@id": "../Leg/v2.0/vocab.jsonld#beckn:Leg"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:items",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "items",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Line items within the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#ContractItem"
      }
    },
    {
      "@id": "beckn:fulfillments",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "fulfillments",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Fulfillments associated with this contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Fulfillment"
      }
    },
    {
      "@id": "beckn:state",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "state",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Current state of the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Journey"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#State"
      }
    }
  ]
}
