  "@graph": [
    {
      "@id": "beckn:FareEstimate",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "FareEstimate",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "An estimated fare for a requested trip, typically returned in response to a search before the booking is confirmed.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:FareBreakup"
      }
    },
    {
      "@id": "beckn:estimatedAmount",
