      "rdfs:label": {
        "@value": "estimatedAmount",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Estimated total fare amount",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FareEstimate"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
