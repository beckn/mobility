{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Passenger",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Passenger",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A person who travels using a transport service and is identified in a booking or travel document.",
        "@language": "en"
      },
      "rdfs:subClassOf": {
        "@id": "https://schema.org/Person"
      }
    },
    {
      "@id": "beckn:passengerId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "passengerId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the passenger in this booking",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:passengerType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "passengerType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Classification of passenger (e.g. ADULT, CHILD, SENIOR, STUDENT)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:specialRequirements",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "specialRequirements",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Accessibility or special assistance requirements",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the participant",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:person",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "person",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Personal details of the participant",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Person"
      }
    },
    {
      "@id": "beckn:organization",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "organization",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Organisation the participant belongs to",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Organization"
      }
    },
    {
      "@id": "beckn:entitlements",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "entitlements",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Entitlements held by the participant",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Passenger"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Entitlement"
      }
    }
  ]
}
