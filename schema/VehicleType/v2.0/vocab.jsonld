{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:VehicleType",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "VehicleType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A class or category of vehicle defined by its mode of transport, capacity, propulsion type, and accessibility features.",
        "@language": "en"
      },
      "rdfs:subClassOf": {
        "@id": "https://schema.org/Vehicle"
      }
    },
    {
      "@id": "beckn:vehicleTypeCode",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "vehicleTypeCode",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Code identifying the vehicle type (e.g. BUS, TRAM, METRO, BICYCLE, SCOOTER)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:maxCapacity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "maxCapacity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Maximum number of passengers the vehicle type can carry",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:propulsionType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "propulsionType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Propulsion type (e.g. ELECTRIC, COMBUSTION, HUMAN, HYBRID)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:wheelchairAccessible",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "wheelchairAccessible",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Whether vehicles of this type are wheelchair accessible",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Boolean"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the category code",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable label for the category",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:parentCategoryId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "parentCategoryId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the parent category if hierarchical",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleType"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
