{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Itinerary",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Itinerary",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A complete planned trip containing an ordered sequence of legs, including transfer points, durations, and timing.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/Trip"
        },
        {
          "@id": "beckn:Leg"
        }
      ]
    },
    {
      "@id": "beckn:legs",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "legs",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Ordered list of legs making up this itinerary",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "beckn:Leg"
      },
      "rdfs:seeAlso": {
        "@id": "../Leg/v2.0/vocab.jsonld#beckn:Leg"
      }
    },
    {
      "@id": "beckn:totalDuration",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "totalDuration",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Total travel duration for the itinerary",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "xsd:duration"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Duration"
      }
    },
    {
      "@id": "beckn:totalDistance",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "totalDistance",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Total distance in metres for the itinerary",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:transferCount",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "transferCount",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of transfers in the itinerary",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:departureTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "departureTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Departure time of the first leg",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:arrivalTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "arrivalTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Arrival time of the last leg",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:items",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "items",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Line items within the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#ContractItem"
      }
    },
    {
      "@id": "beckn:fulfillments",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "fulfillments",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Fulfillments associated with this contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Fulfillment"
      }
    },
    {
      "@id": "beckn:state",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "state",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Current state of the contract",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Itinerary"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#State"
      }
    }
  ]
}
