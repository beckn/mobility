{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:ContactHandle",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "ContactHandle",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A communication handle (such as a phone number, email address, or chat URL) used to contact a driver or support agent in a mobility service.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:handleType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "handleType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of contact handle (PHONE, EMAIL, CHAT, APP)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ContactHandle"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:handle",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "handle",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The actual contact handle value (number, address, or URL)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ContactHandle"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:label",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "label",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable label for this contact handle",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ContactHandle"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:phone",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "phone",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Support phone number",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ContactHandle"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:email",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "email",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Support email address",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ContactHandle"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "url",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "URL to support portal or chat interface",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ContactHandle"
      },
      "rdfs:range": {
        "@id": "xsd:anyURI"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/URL"
      }
    }
  ]
}
