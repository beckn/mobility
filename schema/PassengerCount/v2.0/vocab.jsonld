        "@value": "boardingCount",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of passengers who boarded at the last stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PassengerCount"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
