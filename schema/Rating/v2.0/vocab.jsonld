{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Rating",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Rating",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A numerical or categorical score assigned by a user to a driver, vehicle, or mobility service experience.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:ratedEntityId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "ratedEntityId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the entity being rated (driver, vehicle, service)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:ratedEntityType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "ratedEntityType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of entity being rated (DRIVER, VEHICLE, SERVICE)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:comment",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "comment",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Optional text comment accompanying the rating",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:target",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "target",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The entity being rated, with id and category (Order, Fulfillment, Provider, Agent)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:range",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "range",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Rating scale definition (numeric range or descriptor array)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:ratingValue",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "ratingValue",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Numeric rating value selected by the user",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:feedback",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "feedback",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Textual feedback or written review accompanying the rating",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Rating"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    }
  ]
}
