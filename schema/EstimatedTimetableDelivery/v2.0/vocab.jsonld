        "@value": "Vehicle journeys with estimated timetable data",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EstimatedTimetableDelivery"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleJourney"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleJourney/v2.0/vocab.jsonld#beckn:VehicleJourney"
      }
    },
    {
      "@id": "beckn:validUntil",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validUntil",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Time until which this estimated data is valid",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EstimatedTimetableDelivery"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
