      "rdfs:label": {
        "@value": "responseTimestamp",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp of this delivery response",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EstimatedTimetableDelivery"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:estimatedVehicleJourneys",
