{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:TripDescriptor",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "TripDescriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "An identifier that uniquely references a specific vehicle journey in a real-time transit feed.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:tripId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "tripId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "GTFS trip_id of the trip being referenced",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:routeId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "routeId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "GTFS route_id associated with the trip",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:directionId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "directionId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Direction of travel (0 or 1)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:startTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "startTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Scheduled start time of the trip in HH:MM:SS",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:startDate",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "startDate",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Start date of the trip in YYYYMMDD format",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:scheduleRelationship",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "scheduleRelationship",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Relationship to the GTFS schedule (SCHEDULED, ADDED, UNSCHEDULED, CANCELED)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:name",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "name",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Short display name of the entity",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:short_desc",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "short_desc",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Brief textual description",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:long_desc",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "long_desc",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Detailed or long-form description",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:media",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "media",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Media resource URLs (images, audio, video)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:anyURI"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/URL"
      }
    },
    {
      "@id": "beckn:images",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "images",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Image URLs for visual display",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:TripDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:anyURI"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/URL"
