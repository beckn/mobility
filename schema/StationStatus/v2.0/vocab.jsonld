{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:StationStatus",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "StationStatus",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The real-time operational state of a shared mobility station, including the number of available docks and vehicles.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "https://schema.org/ItemAvailability"
      }
    },
    {
      "@id": "beckn:stationId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stationId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier of the station being reported",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:numBikesAvailable",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "numBikesAvailable",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of bikes currently available for rental",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:numDocksAvailable",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "numDocksAvailable",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of empty docking points currently available",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:isInstalled",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "isInstalled",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Whether the station is physically installed and operational",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Boolean"
      }
    },
    {
      "@id": "beckn:isRenting",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "isRenting",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Whether the station is currently renting bikes",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Boolean"
      }
    },
    {
      "@id": "beckn:isReturning",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "isReturning",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Whether the station is currently accepting bike returns",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Boolean"
      }
    },
    {
      "@id": "beckn:lastReported",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "lastReported",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp of the last status update for this station",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the state",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the state",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:updatedAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "updatedAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp when the state was last updated",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:StationStatus"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    }
  ]
}
