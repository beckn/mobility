{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Entitlement",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Entitlement",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A specific right or benefit granted to a passenger or rider, such as free travel, priority boarding, or a concessionary pass.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:Authority"
      }
    },
    {
      "@id": "beckn:entitlementType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "entitlementType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of entitlement (e.g. FREE_TRAVEL, CONCESSION, PRIORITY)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:eligibilityRules",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "eligibilityRules",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Rules defining who is eligible for this entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:issuingAuthority",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "issuingAuthority",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The authority or operator that issued this entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "beckn:Authority"
      },
      "rdfs:seeAlso": {
        "@id": "../Authority/v2.0/vocab.jsonld#beckn:Authority"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Validity period of the entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable information about the entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:resource",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "resource",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The resource being accessed against this entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#ContractItem"
      }
    },
    {
      "@id": "beckn:credentials",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "credentials",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Credential descriptors for the entitlement",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Entitlement"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    }
  ]
}
