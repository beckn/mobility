{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Timetable",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Timetable",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A structured schedule listing planned arrival and departure times for vehicles at each stop along a route.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/Schedule"
        },
        {
          "@id": "beckn:Route"
        },
        {
          "@id": "beckn:VehicleJourney"
        }
      ]
    },
    {
      "@id": "beckn:routeRef",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "routeRef",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Reference to the route this timetable covers",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "beckn:Route"
      },
      "rdfs:seeAlso": {
        "@id": "../Route/v2.0/vocab.jsonld#beckn:Route"
      }
    },
    {
      "@id": "beckn:trips",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "trips",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Vehicle journeys (trips) in this timetable",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleJourney"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleJourney/v2.0/vocab.jsonld#beckn:VehicleJourney"
      }
    },
    {
      "@id": "beckn:validFrom",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validFrom",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Date from which this timetable is valid",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:validUntil",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validUntil",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Date until which this timetable is valid",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the catalog",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the catalog",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:tags",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "tags",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Tags associated with the catalog",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Timetable"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
