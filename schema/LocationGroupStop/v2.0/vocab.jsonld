      "rdfs:label": {
        "@value": "locationGroupId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the parent location group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:LocationGroupStop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
