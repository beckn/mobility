{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:PickupDropoffPoint",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "PickupDropoffPoint",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A designated location used as a pickup or dropoff point for passengers in a ride-hailing or demand-responsive transport service.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:pdpType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "pdpType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of point (PICKUP, DROPOFF, BOTH)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PickupDropoffPoint"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:landmark",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "landmark",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Nearby landmark or reference point",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PickupDropoffPoint"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:accessNotes",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "accessNotes",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Instructions for accessing this pickup/dropoff point",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PickupDropoffPoint"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the fulfillment stop",
        "@language": "en"
      },
