{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Provider",
  "type": "object",
  "description": "A mobility service provider registered on a MaaS platform, offering transport options to end users.",
  "properties": {
    "providerId": {
      "description": "Unique identifier for the mobility provider",
      "type": "string"
    },
    "providerName": {
      "description": "Human-readable name of the provider",
      "type": "string"
    },
    "categories": {
      "description": "Service categories offered by the provider",
      "$ref": "https://schema.beckn.io/CategoryCode/v2.1/schema.json"
    },
    "id": {
      "description": "Unique identifier for the provider",
      "type": "string"
    },
    "descriptor": {
      "description": "Human-readable description of the provider",
      "$ref": "https://schema.beckn.io/Descriptor/v2.1/schema.json"
    },
    "locations": {
      "description": "Locations where the provider offers services",
      "$ref": "https://schema.beckn.io/Location/v2.0/schema.json"
    },
    "items": {
      "description": "Items available for discovery from this provider",
      "$ref": "https://schema.beckn.io/Item/v2.1/schema.json"
    },
    "fulfillments": {
      "description": "Fulfillment options offered by this provider",
      "$ref": "https://schema.beckn.io/Fulfillment/v2.1/schema.json"
    },
    "ratingsTotal": {
      "description": "Total number of ratings received",
      "type": "number"
    },
    "rating": {
      "description": "Aggregate rating of the provider",
      "$ref": "https://schema.beckn.io/Rating/v2.0/schema.json"
    }
  },
  "additionalProperties": false,
  "x-tags": [
    "redundant"
  ]
}
