        "@value": "stops",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Stops included in this location group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:LocationGroup"
      },
      "rdfs:range": {
        "@id": "beckn:Stop"
      },
      "rdfs:seeAlso": {
        "@id": "../Stop/v2.0/vocab.jsonld#beckn:Stop"
      }
    },
    {
