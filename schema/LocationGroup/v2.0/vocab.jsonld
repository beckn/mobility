  },
  "@graph": [
    {
      "@id": "beckn:LocationGroup",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "LocationGroup",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A set of geographic locations (stops or areas) that can collectively serve as an origin or destination for flexible transit services.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:Stop"
      }
    },
    {
      "@id": "beckn:locationGroupId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "locationGroupId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the location group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:LocationGroup"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:locationGroupName",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "locationGroupName",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable name for the location group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:LocationGroup"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
