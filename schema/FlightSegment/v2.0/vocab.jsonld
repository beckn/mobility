{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:FlightSegment",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "FlightSegment",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A single non-stop flight operated between two airports, forming a unit of an air travel itinerary.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/Flight"
        },
        {
          "@id": "beckn:Route"
        }
      ]
    },
    {
      "@id": "beckn:flightNumber",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "flightNumber",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "IATA/ICAO flight number (e.g. AI101)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FlightSegment"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:departureAirport",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "departureAirport",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "IATA airport code of the departure airport",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FlightSegment"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:arrivalAirport",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "arrivalAirport",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "IATA airport code of the arrival airport",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FlightSegment"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
