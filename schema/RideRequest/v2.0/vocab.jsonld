{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:RideRequest",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "RideRequest",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A passenger's request for an on-demand transport service between two points, specifying origin, destination, and travel preferences.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:VehicleCategory"
      }
    },
    {
      "@id": "beckn:origin",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "origin",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Pickup location for the ride",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:destination",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "destination",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Dropoff location for the ride",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:requestedTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "requestedTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Requested pickup time",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:passengerCount",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "passengerCount",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of passengers",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:vehiclePreference",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "vehiclePreference",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Preferred vehicle category",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleCategory/v2.0/vocab.jsonld#beckn:VehicleCategory"
      }
    },
    {
      "@id": "beckn:textSearch",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "textSearch",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Free-text search query expressing what the traveler is looking for",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:filters",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "filters",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "JSONPath filter criteria applied to the search results",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:spatial",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "spatial",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic constraints on the search area",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#SpatialConstraint"
      }
    },
    {
      "@id": "beckn:provider",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "provider",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of a specific provider to search within",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideRequest"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
