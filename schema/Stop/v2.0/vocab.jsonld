{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Stop",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Stop",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A designated location where vehicles stop to allow passengers to board or alight from a transport service.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/BusStop"
        },
        {
          "@id": "beckn:Station"
        }
      ]
    },
    {
      "@id": "beckn:stopId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:stopCode",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopCode",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Short public-facing code for the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:stopName",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopName",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable name of the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:locationType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "locationType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Classification of location (0=stop, 1=station, 2=entrance, 3=generic_node, 4=boarding_area)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:parentStation",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "parentStation",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Reference to the parent station if this is a platform",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "beckn:Station"
      },
      "rdfs:seeAlso": {
        "@id": "../Station/v2.0/vocab.jsonld#beckn:Station"
      }
    },
    {
      "@id": "beckn:wheelchairBoarding",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "wheelchairBoarding",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Wheelchair accessibility (0=no info, 1=accessible, 2=not accessible)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the fulfillment stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:location",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "location",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic location of the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:type",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "type",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of stop (start, end, intermediate)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:instructions",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "instructions",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Instructions for passengers at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:time",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "time",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Expected time window at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Stop"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    }
  ]
}
