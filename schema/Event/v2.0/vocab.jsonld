{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Event",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Event",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A discrete state change in the lifecycle of a vehicle or mobility asset, such as a trip starting, vehicle reserved, or battery low.",
        "@language": "en"
      },
      "rdfs:subClassOf": {
        "@id": "https://schema.org/Event"
      }
    },
    {
      "@id": "beckn:eventType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "eventType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of lifecycle event (e.g. TRIP_START, VEHICLE_RESERVED, BATTERY_LOW)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:entityId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "entityId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the entity that generated the event",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:triggeredAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "triggeredAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp when the event was triggered",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:payload",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "payload",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Additional event-specific data payload",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the state",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the state",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:updatedAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "updatedAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp when the state was last updated",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Event"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    }
  ]
}
