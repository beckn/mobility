{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Feedback",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Feedback",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A passenger's qualitative assessment or textual comment about a completed trip, driver, or mobility service.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:feedbackText",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "feedbackText",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Textual content of the feedback",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Feedback"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:feedbackType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "feedbackType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Category of feedback (e.g. COMPLIMENT, COMPLAINT, SUGGESTION)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Feedback"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:serviceComponent",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "serviceComponent",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Component of the service being reviewed (e.g. DRIVER, VEHICLE, APP)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Feedback"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the feedback",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Feedback"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Feedback content and form",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Feedback"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:rating",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "rating",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Rating associated with this feedback",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Feedback"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Rating"
      }
    }
  ]
}
