{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:ExchangePoints",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "ExchangePoints",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Locations in a transport network where fixed-route and flexible services connect, enabling passenger interchange.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:VehicleJourney"
      }
    },
    {
      "@id": "beckn:exchangePointType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "exchangePointType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of exchange point (e.g. FIXED_TO_FLEX, FLEX_TO_FLEX)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:connectingServices",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "connectingServices",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Services that connect at this exchange point",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleJourney"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleJourney/v2.0/vocab.jsonld#beckn:VehicleJourney"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the fulfillment stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:location",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "location",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic location of the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:type",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "type",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of stop (start, end, intermediate)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:instructions",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "instructions",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Instructions for passengers at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:time",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "time",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Expected time window at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:ExchangePoints"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    }
  ]
}
