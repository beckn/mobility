{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:CancellationPolicy",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "CancellationPolicy",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A policy defining the terms and conditions under which a transport booking can be cancelled, including applicable refund percentages and cancellation deadlines.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:FareBreakup"
      }
    },
    {
      "@id": "beckn:cancellationFee",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "cancellationFee",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Flat cancellation fee charged upon cancellation",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:gracePeriodMinutes",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "gracePeriodMinutes",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of minutes after booking during which cancellation is free",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:fareComponent",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "fareComponent",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Fare components affected by this cancellation policy",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "beckn:FareBreakup"
      },
      "rdfs:seeAlso": {
        "@id": "../FareBreakup/v2.0/vocab.jsonld#beckn:FareBreakup"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the cancellation policy",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the policy",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:cancellationTerms",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "cancellationTerms",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Terms and conditions governing cancellation",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:refundPercentage",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "refundPercentage",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Percentage of the fare refunded on cancellation",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:cancelByTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "cancelByTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Deadline by which cancellation must be made",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:CancellationPolicy"
      },
      "rdfs:range": {
