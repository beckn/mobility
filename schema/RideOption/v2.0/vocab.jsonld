{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:RideOption",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "RideOption",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A specific ride-hailing vehicle category and pricing option presented to a passenger in response to a ride request.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "beckn:PricingModel"
        },
        {
          "@id": "beckn:VehicleCategory"
        }
      ]
    },
    {
      "@id": "beckn:vehicleType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "vehicleType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Category of vehicle for this ride option",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleCategory/v2.0/vocab.jsonld#beckn:VehicleCategory"
      }
    },
    {
      "@id": "beckn:estimatedArrival",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "estimatedArrival",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Estimated vehicle arrival time at the pickup point",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:estimatedDuration",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "estimatedDuration",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Estimated trip duration",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "xsd:duration"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Duration"
      }
    },
    {
      "@id": "beckn:estimatedDistance",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "estimatedDistance",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Estimated trip distance in kilometres",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:pricingModel",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "pricingModel",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Pricing model applicable to this ride option",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:seeAlso": {
        "@id": "../PricingModel/v2.0/vocab.jsonld#beckn:PricingModel"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:price",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "price",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Price specification for this offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#PriceSpecification"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Validity period of the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    },
    {
      "@id": "beckn:tags",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "tags",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Tags or labels associated with the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:RideOption"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
