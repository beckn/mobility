{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Place",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Place",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A named or unnamed geographic location relevant to mobility, such as an address, point of interest, stop, or area.",
        "@language": "en"
      },
      "owl:equivalentClass": {
        "@id": "https://schema.org/Place"
      }
    },
    {
      "@id": "beckn:placeType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "placeType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of place (e.g. ADDRESS, STOP, POI, STATION, AREA)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:placeName",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "placeName",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable name of the place",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the location",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the location",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:gps",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "gps",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "GPS coordinates as a latitude,longitude string",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:address",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "address",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Physical address of the location",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Address"
      }
    },
    {
      "@id": "beckn:city",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "city",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "City name",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:country",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "country",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "ISO 3166-1 alpha-2 country code",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:geojson",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "geojson",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "GeoJSON geometry object representing this location",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Place"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#GeoJSONGeometry"
      }
    }
  ]
}
