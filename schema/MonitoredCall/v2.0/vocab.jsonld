{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:MonitoredCall",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "MonitoredCall",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A real-time arrival or departure prediction for a specific vehicle at a specific stop within a monitored journey.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:StopPoint"
      }
    },
    {
      "@id": "beckn:stopPointRef",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopPointRef",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Reference to the stop point for this call",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "beckn:StopPoint"
      },
      "rdfs:seeAlso": {
        "@id": "../StopPoint/v2.0/vocab.jsonld#beckn:StopPoint"
      }
    },
    {
      "@id": "beckn:visitNumber",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "visitNumber",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Visit sequence number for loop services",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:vehicleAtStop",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "vehicleAtStop",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Whether the vehicle is currently at the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Boolean"
      }
    },
    {
      "@id": "beckn:expectedArrivalTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "expectedArrivalTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Predicted arrival time at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:expectedDepartureTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "expectedDepartureTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Predicted departure time from this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:aimedArrivalTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "aimedArrivalTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Scheduled arrival time from the timetable",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:aimedDepartureTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "aimedDepartureTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Scheduled departure time from the timetable",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:arrivalStatus",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "arrivalStatus",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Arrival status (e.g. onTime, delayed, early)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:departureStatus",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "departureStatus",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Departure status (e.g. onTime, delayed, early)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the tracking record",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "url",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "URL endpoint for real-time tracking information",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "xsd:anyURI"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/URL"
      }
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "status",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Current tracking status",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#State"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Validity period for this tracking record",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:MonitoredCall"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    }
  ]
}
