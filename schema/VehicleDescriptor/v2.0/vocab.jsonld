      "rdfs:label": {
        "@value": "licensePlate",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Vehicle license plate number",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:name",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "name",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Short display name of the entity",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:short_desc",
