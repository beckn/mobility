      "rdfs:label": {
        "@value": "short_desc",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Brief textual description",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleDescriptor"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
