    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Station",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Station",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A major transit facility serving as a hub for one or more transport modes, typically offering waiting areas, ticketing, and interchange facilities.",
        "@language": "en"
      },
      "rdfs:subClassOf": {
        "@id": "https://schema.org/CivicStructure"
      },
      "rdfs:seeAlso": [
        {
          "@id": "https://schema.org/TrainStation"
        },
        {
          "@id": "https://schema.org/BusStation"
        },
        {
          "@id": "beckn:Level"
        },
        {
          "@id": "beckn:Pathway"
        },
        {
          "@id": "beckn:Quay"
        }
      ]
    },
    {
      "@id": "beckn:stationId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stationId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the station",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Station"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:stationName",
      "@type": "rdf:Property",
