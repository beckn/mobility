        "@value": "stationName",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable name of the station",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Station"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:stationType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stationType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Primary transport mode served (e.g. RAIL, BUS, METRO, FERRY)",
