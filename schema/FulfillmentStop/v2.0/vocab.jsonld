{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:FulfillmentStop",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "FulfillmentStop",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A specific location associated with a fulfillment (trip or journey) at which passengers board, alight, or transfer between services.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "beckn:PassengerCount"
        },
        {
          "@id": "beckn:Stop"
        }
      ]
    },
    {
      "@id": "beckn:stopType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Role of this stop in the fulfillment (START, END, INTERMEDIATE)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:scheduledTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "scheduledTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Scheduled arrival or departure time at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:actualTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "actualTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Actual arrival or departure time at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:stopRef",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopRef",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Reference to the Stop entity for this fulfillment stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "beckn:Stop"
      },
      "rdfs:seeAlso": {
        "@id": "../Stop/v2.0/vocab.jsonld#beckn:Stop"
      }
    },
    {
      "@id": "beckn:passengerCount",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "passengerCount",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Passenger count at this fulfillment stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "beckn:PassengerCount"
      },
      "rdfs:seeAlso": {
        "@id": "../PassengerCount/v2.0/vocab.jsonld#beckn:PassengerCount"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the fulfillment stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:location",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "location",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic location of the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:type",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "type",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of stop (start, end, intermediate)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:instructions",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "instructions",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Instructions for passengers at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:time",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "time",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Expected time window at this stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FulfillmentStop"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    }
  ]
}
