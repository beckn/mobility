        "@value": "fareProductId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the fare product this transfer rule applies to",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:FareTransferRule"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
