      "rdfs:label": {
        "@value": "location",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic location of the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Transfer"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:type",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "type",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of stop (start, end, intermediate)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Transfer"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
