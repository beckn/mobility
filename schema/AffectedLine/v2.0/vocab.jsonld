{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:AffectedLine",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "AffectedLine",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A reference to a transport line that is affected by a service disruption or alert.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "beckn:Line"
        },
        {
          "@id": "beckn:Stop"
        }
      ]
    },
    {
      "@id": "beckn:lineId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "lineId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the affected transport line",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:AffectedLine"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:lineRef",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "lineRef",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Reference to the affected Line entity",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:AffectedLine"
      },
      "rdfs:range": {
        "@id": "beckn:Line"
      },
      "rdfs:seeAlso": {
        "@id": "../Line/v2.0/vocab.jsonld#beckn:Line"
      }
    },
    {
      "@id": "beckn:affectedStops",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "affectedStops",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Stops on this line affected by the disruption",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:AffectedLine"
      },
      "rdfs:range": {
        "@id": "beckn:Stop"
      },
      "rdfs:seeAlso": {
        "@id": "../Stop/v2.0/vocab.jsonld#beckn:Stop"
      }
    },
    {
      "@id": "beckn:cause",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "cause",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Cause of the disruption affecting this line",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:AffectedLine"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the alert",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:AffectedLine"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
