      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Time period during which the alert is active",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:AffectedLine"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
