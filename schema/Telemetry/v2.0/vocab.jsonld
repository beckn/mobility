{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Telemetry",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Telemetry",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Time-series data streams reporting the real-time location, speed, and operational state of a mobility vehicle or asset.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "https://schema.org/Vehicle"
      }
    },
    {
      "@id": "beckn:vehicleId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "vehicleId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the vehicle transmitting telemetry",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:timestamp",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "timestamp",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp of the telemetry reading",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:latitude",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "latitude",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Latitude in WGS-84 decimal degrees",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:longitude",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "longitude",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Longitude in WGS-84 decimal degrees",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:speed",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "speed",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Current speed in kilometres per hour",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:bearing",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "bearing",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Direction of travel in degrees (0=north, 90=east)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:batteryLevel",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "batteryLevel",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Battery charge percentage (for electric vehicles)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:odometer",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "odometer",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Odometer reading in metres since vehicle start",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the tracking record",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:url",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "url",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "URL endpoint for real-time tracking information",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "xsd:anyURI"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/URL"
      }
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "status",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Current tracking status",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#State"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Validity period for this tracking record",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Telemetry"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    }
  ]
}
