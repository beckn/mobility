{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:VehicleCategory",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "VehicleCategory",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A broad classification of vehicles by their physical type, such as two-wheeler, three-wheeler, four-wheeler, or bus.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:vehicleCategoryCode",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "vehicleCategoryCode",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Code for the vehicle category (e.g. TWO_WHEELER, THREE_WHEELER, FOUR_WHEELER, BUS)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:maxPassengers",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "maxPassengers",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Maximum number of passengers for vehicles in this category",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the category code",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable label for the category",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:parentCategoryId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "parentCategoryId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Identifier of the parent category if hierarchical",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:VehicleCategory"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
