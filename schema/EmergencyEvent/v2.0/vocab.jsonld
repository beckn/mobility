{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:EmergencyEvent",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "EmergencyEvent",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A critical safety or operational event requiring immediate response, such as an accident, vehicle breakdown, or passenger emergency.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "https://schema.org/Event"
      }
    },
    {
      "@id": "beckn:emergencyType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "emergencyType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of emergency (e.g. ACCIDENT, BREAKDOWN, MEDICAL)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:severity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "severity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Severity level of the emergency (LOW, MEDIUM, HIGH, CRITICAL)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:reportedAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "reportedAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Timestamp when the emergency was reported",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:location",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "location",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Geographic location of the emergency",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Location"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the alert",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the alert",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Time period during which the alert is active",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    },
    {
      "@id": "beckn:status",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "status",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Current status of the alert",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:EmergencyEvent"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#State"
      }
    }
  ]
}
