      "rdfs:label": {
        "@value": "groupId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for this passenger group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PassengerGroup"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
