      "rdfs:label": {
        "@value": "PassengerGroup",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A collection of passengers traveling together as a group, with a group size and a designated lead passenger.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:Passenger"
      }
    },
    {
