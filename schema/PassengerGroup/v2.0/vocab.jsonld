      "rdfs:label": {
        "@value": "leadPassenger",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The lead or primary passenger for the group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PassengerGroup"
      },
      "rdfs:range": {
        "@id": "beckn:Passenger"
      },
      "rdfs:seeAlso": {
