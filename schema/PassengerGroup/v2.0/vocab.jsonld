        "@value": "groupSize",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Total number of passengers in the group",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PassengerGroup"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
