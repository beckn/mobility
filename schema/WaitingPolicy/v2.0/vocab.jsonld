{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:WaitingPolicy",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "WaitingPolicy",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Rules governing the maximum time a driver is required to wait for a passenger at the pickup location before being permitted to cancel the booking.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:freeWaitingTimeMinutes",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "freeWaitingTimeMinutes",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Number of minutes the driver waits for free before charging",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:maxWaitingTimeMinutes",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "maxWaitingTimeMinutes",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Maximum total minutes the driver will wait before auto-cancelling",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:chargePerExtraMinute",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "chargePerExtraMinute",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Additional charge per minute beyond the free waiting time",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:currency",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "currency",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "ISO 4217 currency code for waiting charges",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the policy",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:policyType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "policyType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of policy (extensible term)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
