      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the policy",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:WaitingPolicy"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Validity window for this policy version",
        "@language": "en"
      },
      "rdfs:domain": {
