{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Interchange",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Interchange",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A planned transfer connection point where passengers switch between two or more transport services, with defined timing constraints.",
        "@language": "en"
      },
      "rdfs:seeAlso": [
        {
          "@id": "beckn:Station"
        },
        {
          "@id": "beckn:Stop"
        },
        {
          "@id": "beckn:VehicleJourney"
        }
      ]
    },
    {
      "@id": "beckn:minTransferTime",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "minTransferTime",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Minimum required transfer time in seconds",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:transferType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "transferType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of interchange (e.g. TIMED, GUARANTEED, IN_SEAT)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:fromStopId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "fromStopId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The stop passengers transfer from",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "beckn:Stop"
      },
      "rdfs:seeAlso": {
        "@id": "../Stop/v2.0/vocab.jsonld#beckn:Stop"
      }
    },
    {
      "@id": "beckn:toStopId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "toStopId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The stop passengers transfer to",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "beckn:Stop"
      },
      "rdfs:seeAlso": {
        "@id": "../Stop/v2.0/vocab.jsonld#beckn:Stop"
      }
    },
    {
      "@id": "beckn:fromTripId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "fromTripId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The vehicle journey passengers transfer from",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleJourney"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleJourney/v2.0/vocab.jsonld#beckn:VehicleJourney"
      }
    },
    {
      "@id": "beckn:toTripId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "toTripId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The vehicle journey passengers transfer to",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "beckn:VehicleJourney"
      },
      "rdfs:seeAlso": {
        "@id": "../VehicleJourney/v2.0/vocab.jsonld#beckn:VehicleJourney"
      }
    },
    {
      "@id": "beckn:stopId",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopId",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:stopCode",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopCode",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Short public-facing code for the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:stopName",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "stopName",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable name of the stop",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:locationType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "locationType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Classification of location (0=stop, 1=station, 2=entrance, 3=generic_node, 4=boarding_area)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:parentStation",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "parentStation",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Reference to the parent station if this is a platform",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "beckn:Station"
      },
      "rdfs:seeAlso": {
        "@id": "../Station/v2.0/vocab.jsonld#beckn:Station"
      }
    },
    {
      "@id": "beckn:wheelchairBoarding",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "wheelchairBoarding",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Wheelchair accessibility (0=no info, 1=accessible, 2=not accessible)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Interchange"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
