      "rdfs:label": {
        "@value": "lines",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Lines that belong to this network",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Network"
      },
      "rdfs:range": {
        "@id": "beckn:Line"
      },
      "rdfs:seeAlso": {
        "@id": "../Line/v2.0/vocab.jsonld#beckn:Line"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the catalog",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Network"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
