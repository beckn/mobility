{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:Review",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "Review",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A written review or opinion submitted by a passenger about a completed mobility service, driver, or vehicle.",
        "@language": "en"
      },
      "rdfs:seeAlso": {
        "@id": "beckn:Rider"
      }
    },
    {
      "@id": "beckn:reviewText",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "reviewText",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The written text of the review",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:reviewedAt",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "reviewedAt",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Date and time the review was submitted",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "xsd:dateTime"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/DateTime"
      }
    },
    {
      "@id": "beckn:reviewer",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "reviewer",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The passenger who submitted this review",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "beckn:Rider"
      },
      "rdfs:seeAlso": {
        "@id": "../Rider/v2.0/vocab.jsonld#beckn:Rider"
      }
    },
    {
      "@id": "beckn:target",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "target",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The entity being rated, with id and category (Order, Fulfillment, Provider, Agent)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:range",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "range",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Rating scale definition (numeric range or descriptor array)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:ratingValue",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "ratingValue",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Numeric rating value selected by the user",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:feedback",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "feedback",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Textual feedback or written review accompanying the rating",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:Review"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    }
  ]
}
