{
  "@context": {
    "beckn": "https://schema.beckn.io/linked-data/latest-context.jsonld",
    "schema": "https://schema.org/version/latest/schemaorg-current-https.jsonld",
    "owl": "http://www.w3.org/2002/07/owl#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "xsd": "http://www.w3.org/2001/XMLSchema#"
  },
  "@graph": [
    {
      "@id": "beckn:PricingModel",
      "@type": "owl:Class",
      "rdfs:label": {
        "@value": "PricingModel",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The pricing structure or tariff model used by a mobility service provider to calculate fares.",
        "@language": "en"
      }
    },
    {
      "@id": "beckn:modelType",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "modelType",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Type of pricing model (e.g. FIXED, METERED, SUBSCRIPTION, SURGE)",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:baseRate",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "baseRate",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Base fare charged at the start of a trip",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:perMinuteRate",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "perMinuteRate",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Additional charge per minute of travel",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:perKmRate",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "perKmRate",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Additional charge per kilometre of travel",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:decimal"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Number"
      }
    },
    {
      "@id": "beckn:currency",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "currency",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "ISO 4217 currency code",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:surgeEnabled",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "surgeEnabled",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Whether surge pricing can be applied",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:boolean"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Boolean"
      }
    },
    {
      "@id": "beckn:id",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "id",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Unique identifier for the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    },
    {
      "@id": "beckn:descriptor",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "descriptor",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Human-readable description of the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#Descriptor"
      }
    },
    {
      "@id": "beckn:price",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "price",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Price specification for this offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#PriceSpecification"
      }
    },
    {
      "@id": "beckn:validity",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "validity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Validity period of the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "https://schema.beckn.io/core/v2.0/#TimePeriod"
      }
    },
    {
      "@id": "beckn:tags",
      "@type": "rdf:Property",
      "rdfs:label": {
        "@value": "tags",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "Tags or labels associated with the offer",
        "@language": "en"
      },
      "rdfs:domain": {
        "@id": "beckn:PricingModel"
      },
      "rdfs:range": {
        "@id": "xsd:string"
      },
      "skos:closeMatch": {
        "@id": "https://schema.org/Text"
      }
    }
  ]
}
