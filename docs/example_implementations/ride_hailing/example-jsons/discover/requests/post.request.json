    "try": false,
    "ttl": "<ttl>",
    "schemaContext": [
      "https://schema.beckn.io/TripRequest/2.0/context.jsonld"
    ],
    "requestDigest": {
      "digest": "<digest:pattern ^BLAKE-512=[A-Za-z0-9+/]+=*$>"
